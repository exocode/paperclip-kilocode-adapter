{
  "name": "@exocode/paperclip-kilocode-adapter",
  "version": "0.2.8",
  "description": "Paperclip external adapter plugin for the Kilo Code CLI",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "homepage": "https://github.com/exocode/paperclip-kilocode-adapter",
  "repository": {
    "type": "git",
    "url": "https://github.com/exocode/paperclip-kilocode-adapter"
  },
  "bugs": {
    "url": "https://github.com/exocode/paperclip-kilocode-adapter/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server/index.js",
    "./ui-parser": "./dist/ui-parser.js"
  },
  "paperclip": {
    "adapterUiParser": "1.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "0.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3"
  }
}
